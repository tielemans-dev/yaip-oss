generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Better Auth Core Models ──

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  invitations   Invitation[]

  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime
  updatedAt            DateTime
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ── Organization Models ──

model Organization {
  id                   String       @id
  name                 String
  slug                 String       @unique
  logo                 String?
  metadata             String?
  createdAt            DateTime
  stripeCustomerId     String?      @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  subscriptionStatus   String?      @default("free")
  members              Member[]
  invitations          Invitation[]
  contacts             Contact[]
  catalogItems         CatalogItem[]
  taxIds               OrganizationTaxId[]
  invoices             Invoice[]
  quotes               Quote[]
  settings             OrgSettings?

  @@map("organization")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  createdAt      DateTime

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  inviterId      String
  inviter        User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  createdAt      DateTime

  @@index([organizationId])
  @@index([inviterId])
  @@map("invitation")
}

// ── App Models ──

model InstallationState {
  id              String   @id @default("default")
  isSetupComplete Boolean  @default(false)
  distribution    String   @default("selfhost")
  setupVersion    Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("installation_state")
}

model OrgSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  countryCode    String       @default("US")
  locale         String       @default("en-US")
  timezone       String       @default("UTC")
  defaultCurrency String      @default("USD")
  taxRegime      String       @default("us_sales_tax")
  pricesIncludeTax Boolean    @default(false)
  currency       String       @default("USD")
  taxRate        Decimal?     @db.Decimal(5, 2)
  companyName    String?
  companyAddress String?
  companyEmail   String?
  companyPhone   String?
  companyLogo    String?
  invoicePrefix  String       @default("INV")
  invoiceNextNum Int          @default(1)
  quotePrefix    String       @default("QTE")
  quoteNextNum   Int          @default(1)
  onboardingStatus String     @default("not_started")
  onboardingMethod String?
  onboardingProfile String?
  onboardingVersion Int?
  onboardingCompletedAt DateTime?
  aiOpenRouterApiKeyEnc String?
  aiOpenRouterModel String @default("openai/gpt-4o-mini")
  stripePublishableKey String?
  stripeSecretKeyEnc String?
  stripeWebhookSecretEnc String?
  documentSendingDomain String?
  documentSendingDomainProviderId String?
  documentSendingDomainStatus String?
  documentSendingDomainRecords Json?
  documentSendingDomainFailureReason String?
  documentSendingDomainVerifiedAt DateTime?
  documentSendingLastSyncedAt DateTime?
  documentSendingLastSyncSource String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("org_settings")
}

model Contact {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  company        String?
  address        String?
  city           String?
  state          String?
  zip            String?
  country        String?
  taxId          String?
  taxIds         ContactTaxId[]
  notes          String?
  invoices       Invoice[]
  quotes         Quote[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@map("contact")
}

model CatalogItem {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  description      String?
  defaultUnitPrice Decimal      @db.Decimal(12, 2)
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("catalog_item")
}

model OrganizationTaxId {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scheme         String
  value          String
  countryCode    String?
  isPrimary      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, scheme])
  @@map("organization_tax_id")
}

model ContactTaxId {
  id          String    @id @default(cuid())
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  scheme      String
  value       String
  countryCode String?
  isPrimary   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([contactId])
  @@index([contactId, scheme])
  @@map("contact_tax_id")
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId      String
  contact        Contact       @relation(fields: [contactId], references: [id])
  number         String
  status         String        @default("draft")
  issueDate      DateTime      @default(now())
  dueDate        DateTime
  supplyDate     DateTime?
  subtotalNet    Decimal       @db.Decimal(12, 2)
  totalTax       Decimal       @db.Decimal(12, 2) @default(0)
  totalGross     Decimal       @db.Decimal(12, 2)
  currency       String        @default("USD")
  countryCode    String        @default("US")
  locale         String        @default("en-US")
  timezone       String        @default("UTC")
  taxRegime      String        @default("us_sales_tax")
  pricesIncludeTax Boolean     @default(false)
  sellerSnapshot Json?
  buyerSnapshot  Json?
  complianceStatus String      @default("valid")
  complianceErrors Json?
  legalText      Json?
  paymentStatus  String        @default("unpaid")
  paidAt         DateTime?
  publicPaymentIssuedAt DateTime?
  publicPaymentKeyVersion Int @default(1)
  lastEmailAttemptAt DateTime?
  lastEmailAttemptOutcome String?
  lastEmailAttemptCode String?
  lastEmailAttemptMessage String?
  stripeCheckoutSessionId String?
  stripePaymentIntentId String?
  paymentFailureReason String?
  paymentReference String?
  purchaseOrderRef String?
  einvoiceFormat String?
  einvoiceStatus String?
  einvoiceExternalId String?
  notes          String?
  items          InvoiceItem[]
  quoteId        String?
  quote          Quote?        @relation(fields: [quoteId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([contactId])
  @@index([organizationId, status])
  @@index([organizationId, paymentStatus])
  @@index([organizationId, publicPaymentIssuedAt])
  @@map("invoice")
}

model InvoiceItem {
  id             String  @id @default(cuid())
  invoiceId      String
  invoice        Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description    String
  quantity       Decimal @db.Decimal(10, 2)
  unitPriceNet   Decimal @db.Decimal(12, 2)
  unitPriceGross Decimal @db.Decimal(12, 2)
  lineNet        Decimal @db.Decimal(12, 2)
  lineTax        Decimal @db.Decimal(12, 2) @default(0)
  lineGross      Decimal @db.Decimal(12, 2)
  taxRate        Decimal @db.Decimal(5, 2)
  taxCategory    String  @default("standard")
  taxCode        String?
  sortOrder      Int     @default(0)

  @@index([invoiceId])
  @@map("invoice_item")
}

model Quote {
  id             String      @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId      String
  contact        Contact     @relation(fields: [contactId], references: [id])
  number         String
  status         String      @default("draft")
  issueDate      DateTime    @default(now())
  expiryDate     DateTime
  supplyDate     DateTime?
  subtotalNet    Decimal     @db.Decimal(12, 2)
  totalTax       Decimal     @db.Decimal(12, 2) @default(0)
  totalGross     Decimal     @db.Decimal(12, 2)
  currency       String      @default("USD")
  countryCode    String      @default("US")
  locale         String      @default("en-US")
  timezone       String      @default("UTC")
  taxRegime      String      @default("us_sales_tax")
  pricesIncludeTax Boolean   @default(false)
  sellerSnapshot Json?
  buyerSnapshot  Json?
  complianceStatus String    @default("valid")
  complianceErrors Json?
  legalText      Json?
  purchaseOrderRef String?
  paymentReference String?
  publicAccessKeyVersion Int @default(1)
  publicAccessIssuedAt DateTime?
  publicDecisionAt DateTime?
  publicRejectionReason String?
  lastEmailAttemptAt DateTime?
  lastEmailAttemptOutcome String?
  lastEmailAttemptCode String?
  lastEmailAttemptMessage String?
  notes          String?
  items          QuoteItem[]
  invoices       Invoice[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([contactId])
  @@index([organizationId, status])
  @@index([organizationId, publicDecisionAt])
  @@map("quote")
}

model QuoteItem {
  id             String @id @default(cuid())
  quoteId        String
  quote          Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description    String
  quantity       Decimal @db.Decimal(10, 2)
  unitPriceNet   Decimal @db.Decimal(12, 2)
  unitPriceGross Decimal @db.Decimal(12, 2)
  lineNet        Decimal @db.Decimal(12, 2)
  lineTax        Decimal @db.Decimal(12, 2) @default(0)
  lineGross      Decimal @db.Decimal(12, 2)
  taxRate        Decimal @db.Decimal(5, 2)
  taxCategory    String  @default("standard")
  taxCode        String?
  sortOrder      Int     @default(0)

  @@index([quoteId])
  @@map("quote_item")
}
