{
  "name": "@yaip/oss",
  "version": "0.1.4",
  "private": false,
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "files": [
    "build",
    "generated",
    "prisma",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./src/router.tsx",
    "./auth-client": "./src/lib/auth-client.ts",
    "./auth/providers": "./src/lib/auth/providers.ts",
    "./build": "./build/index.mjs",
    "./document-email-sending": "./src/lib/document-email-sending.ts",
    "./email": "./src/lib/email.ts",
    "./onboarding/ai-contract": "./src/lib/onboarding/ai-contract.ts",
    "./onboarding/ai-fallback": "./src/lib/onboarding/ai-fallback.ts",
    "./permissions": "./src/lib/permissions.ts",
    "./redirect-target": "./src/lib/redirect-target.ts",
    "./runtime": "./src/lib/runtime/bootstrap.ts",
    "./runtime/auth-config": "./src/lib/runtime/auth-config.ts",
    "./runtime/extensions": "./src/lib/runtime/extensions.ts",
    "./runtime/platform": "./src/lib/runtime/platform.ts",
    "./runtime/services": "./src/lib/runtime/services.ts",
    "./styles.css": "./src/styles.css"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:start": "../../scripts/dev-db-start.sh",
    "db:stop": "docker stop ${YAIP_DB_CONTAINER_NAME:-yaip-postgres}",
    "db:logs": "docker logs -f ${YAIP_DB_CONTAINER_NAME:-yaip-postgres}",
    "i18n:check": "node ../../scripts/i18n-check.mjs && node ../../scripts/i18n-tm-guard.mjs",
    "i18n:update-tm-allowlist": "node ../../scripts/update-tm-allowlist.mjs",
    "migrate": "bun run db:start && bun run prisma:migrate",
    "predev": "bun run prisma:generate && node ../../scripts/predev-bootstrap.mjs",
    "prebuild": "bun run prisma:generate",
    "pretest": "bun run prisma:generate",
    "dev": "YAIP_DISTRIBUTION=selfhost VITE_YAIP_DISTRIBUTION=selfhost node ../../scripts/run-with-workspace-env.mjs bunx vite dev --port 3000",
    "build": "node ../../scripts/run-with-workspace-env.mjs bunx vite build",
    "preview": "node ../../scripts/run-with-workspace-env.mjs bunx vite preview",
    "lint": "oxlint --deny-warnings --report-unused-disable-directives .",
    "typecheck": "tsc --noEmit -p tsconfig.quality.json",
    "typecheck:app": "tsc --noEmit -p tsconfig.json",
    "test": "bun run i18n:check && node ../../scripts/run-with-workspace-env.mjs bunx vitest run -c vitest.config.ts",
    "test:integration": "node ../../scripts/run-with-workspace-env.mjs bunx vitest run -c vitest.config.ts src/trpc/routers/__tests__/*.integration.test.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@yaip/contracts": "workspace:*",
    "@yaip/shared": "workspace:*",
    "@react-pdf/renderer": "^4.3.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "@trpc/client": "^11.10.0",
    "@trpc/react-query": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "better-auth": "^1.4.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "effect": "^3.19.19",
    "lucide-react": "^0.561.0",
    "nitro": "npm:nitro-nightly@latest",
    "pg": "^8.19.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "recharts": "^2.15.4",
    "resend": "^6.9.2",
    "stripe": "^20.4.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.19",
    "@tanstack/devtools-vite": "^0.3.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@playwright/test": "^1.56.0",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.3.1",
    "jsdom": "^27.0.0",
    "oxlint": "^1.50.0",
    "prisma": "^7.4.1",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
