{
  "name": "@yaip/workspace",
  "version": "0.1.4",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "packageManager": "bun@1.3.9",
  "type": "module",
  "workspaces": [
    ".",
    "apps/*",
    "packages/*",
    "scripts"
  ],
  "scripts": {
    "dev": "bun --filter @yaip/oss dev",
    "build": "turbo run build --filter=@yaip/oss",
    "preview": "bun --filter @yaip/oss preview",
    "lint": "turbo run lint --filter=@yaip/oss --filter=@yaip/scripts --filter=@yaip/contracts --filter=@yaip/shared",
    "typecheck": "turbo run typecheck --filter=@yaip/oss --filter=@yaip/scripts --filter=@yaip/contracts --filter=@yaip/shared",
    "typecheck:app": "bun --filter @yaip/oss typecheck:app",
    "test": "turbo run test --filter=@yaip/oss --filter=@yaip/scripts --filter=@yaip/contracts --filter=@yaip/shared",
    "test:e2e": "bun --filter @yaip/oss test:e2e",
    "test:integration": "bun --filter @yaip/oss test:integration",
    "db:start": "bun --filter @yaip/oss db:start",
    "db:stop": "bun --filter @yaip/oss db:stop",
    "db:logs": "bun --filter @yaip/oss db:logs",
    "prisma:generate": "bun --filter @yaip/oss prisma:generate",
    "prisma:migrate": "bun --filter @yaip/oss prisma:migrate",
    "migrate": "bun --filter @yaip/oss migrate",
    "i18n:check": "bun --filter @yaip/oss i18n:check",
    "i18n:update-tm-allowlist": "bun --filter @yaip/oss i18n:update-tm-allowlist"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "nitro": "npm:nitro-nightly@latest",
    "oxlint": "^1.50.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
